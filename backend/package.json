{
    "name": "Neyofit-backend",
    "version": "1.0.0",
    "description": "Neyofit Backend API",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "dev": "nodemon --watch src --exec tsx src/server.ts",
        "dev:tsx": "tsx --tsconfig tsconfig.json src/server.ts",
        "build": "tsup src/server.ts --format esm --out-dir dist --clean --dts",
        "start": "node dist/server.js",
        "clean": "rm -rf dist",
        "seed": "tsx --tsconfig tsconfig.json src/seed/seed.ts"
    },
    "keywords": [
        "express",
        "typescript",
        "mongoose",
        "mongodb"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "ejs": "^4.0.1",
        "express": "^4.18.2",
        "express-rate-limit": "^8.0.1",
        "google-auth-library": "^10.5.0",
        "googleapis": "^171.4.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.0",
        "ms": "^2.1.3",
        "multer": "^2.0.2",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.1",
        "razorpay": "^2.9.6",
        "sharp": "^0.34.5",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/ejs": "^3.1.5",
        "@types/express": "^4.17.21",
        "@types/express-rate-limit": "^5.1.3",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/ms": "^2.1.0",
        "@types/multer": "^2.0.0",
        "@types/node": "^20.8.0",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^7.0.10",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "nodemon": "^3.0.1",
        "tsc-alias": "^1.8.16",
        "tsup": "^8.5.0",
        "tsx": "^4.1.0",
        "typedoc": "^0.28.11",
        "typedoc-plugin-markdown": "^4.8.1",
        "typescript": "^5.2.0"
    }
}