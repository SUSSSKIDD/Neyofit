# Backend Environment Variables Example
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control!

# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Connection
# Format: mongodb://username:password@host:port/database?authSource=admin
MONGODB_URI=mongodb://neyofit_user:your_secure_password@mongodb:27017/neyofit?authSource=admin

# CORS Configuration (comma-separated for multiple origins)
# Frontend URL - used for CORS and email links
CORS_ORIGIN=https://neyofit.in
FRONTEND_URL=https://neyofit.in
PUBLIC_API_URL=https://api.neyofit.in

# JWT Configuration (generate with: openssl rand -base64 48)
# MUST be at least 32 characters
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption Key for Bank Details (generate with: openssl rand -hex 32)
# MUST be exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-key
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret-from-razorpay-dashboard

# Email Configuration (Nodemailer)
# EMAIL_HOST=smtp.yourprovider.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@domain.com
# EMAIL_PASS=your-email-password
# EMAIL_FROM=Neyofit <noreply@neyofit.in>