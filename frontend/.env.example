# Frontend Environment Variables Example
# Copy this file to .env.local (for local dev) or .env.production (for production)
# NEVER commit .env files to version control!

# Admin Secret (for admin-only features)
NEXT_PUBLIC_ADMIN_SECRET=your-admin-secret

# Razorpay Public Key (from Razorpay Dashboard -> Settings -> API Keys)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx

# Google Maps API Key (from Google Cloud Console)
# Restrict to your domains: neyofit.in, api.neyofit.in
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Backend API Base URL
# Production: https://api.neyofit.in/api/v1
# Development: http://localhost:5001/api/v1
NEXT_PUBLIC_API_BASE_URL=https://api.neyofit.in/api/v1